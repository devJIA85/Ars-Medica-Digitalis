        {
          "id": "reading",
          "type": "boolean",
          "title": "Lee y ejecuta la instrucción 'Cierre los ojos'",
          "maxScore": 1
        },
        {
          "id": "writing",
          "type": "boolean",
          "title": "Escribe una frase con sujeto y predicado",
