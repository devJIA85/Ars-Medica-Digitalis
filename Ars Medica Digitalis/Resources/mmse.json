        { "id": "calc1", "type": "boolean", "title": "30 → 27", "maxScore": 1 },
        { "id": "calc2", "type": "boolean", "title": "27 → 24", "maxScore": 1 },
        { "id": "calc3", "type": "boolean", "title": "24 → 21", "maxScore": 1 },
        { "id": "calc4", "type": "boolean", "title": "21 → 18", "maxScore": 1 },
        { "id": "calc5", "type": "boolean", "title": "18 → 15", "maxScore": 1 }
      ]
    },
    {
      "id": "recall",
      "title": "Recuerdo diferido",
      "maxScore": 3,
      "items": [
        { "id": "recall_word1", "type": "boolean", "title": "Recuerda palabra 1", "maxScore": 1 },
        { "id": "recall_word2", "type": "boolean", "title": "Recuerda palabra 2", "maxScore": 1 },
        { "id": "recall_word3", "type": "boolean", "title": "Recuerda palabra 3", "maxScore": 1 }
