      { "min": 18, "max": 23, "label": "Deterioro cognitivo leve", "severity": "mild", "color": "orange" },
      { "min": 10, "max": 17, "label": "Deterioro cognitivo moderado", "severity": "moderate", "color": "red" },
      { "min": 0, "max": 9, "label": "Deterioro cognitivo severo", "severity": "severe", "color": "purple" }
